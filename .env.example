# IBM Cloud API Key
IBM_CLOUD_API_KEY=your_api_key_here

# IBM Cloud Account ID
IBM_CLOUD_ACCOUNT_ID=your_account_id_here

# IBM Cloud Region (e.g., us-south, us-east, eu-gb, eu-de, jp-tok, au-syd)
IBM_CLOUD_REGION=us-south

# IBM Cloud Object Storage Configuration
IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_API_KEY=your_cos_api_key_here
IBM_COS_INSTANCE_CRN=your_cos_instance_crn_here

# VPC Configuration
IBM_VPC_GENERATION=2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/ibm_cloud_collector.log

# Output Configuration
OUTPUT_DIR=output
